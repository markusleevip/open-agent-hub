# Open Agent Hub backend environment variables
# Copy to .env and adjust as needed; all items have defaults (shown in parentheses when unset).
# Production deployments MUST override items marked [secret].

# ---- HTTP ports ----
CONSOLE_PORT=8084          # SaaS Console REST API
MCP_PORT=8085              # MCP Gateway (JSON-RPC over HTTP)

# ---- Database ----
DB_TYPE=sqlite             # sqlite (dev) | postgres (prod)
DB_DSN=data/openagenthub.db   # SQLite file path, or Postgres DSN

# ---- Auth [secret] ----
JWT_SECRET=change-me-in-production   # JWT signing key — must override in production
JWT_EXPIRE_HOURS=168                 # JWT TTL in hours, default 7 days

# ---- Default admin [secret] ----
BOOTSTRAP_USERNAME=admin
BOOTSTRAP_PASSWORD=change-me          # defaults to admin123 — change in production

# ---- Encryption [secret] ----
ENCRYPTION_KEY=change-me-32-bytes-key   # encrypts connected-server auth_config (first 32 bytes)

# ---- Optional ----
REDIS_ADDR=                # reserved: rate-limit/cache (not yet wired)
ENABLE_CONFIRMATION=false  # two-step confirmation handshake for high-risk tools (__confirm)
